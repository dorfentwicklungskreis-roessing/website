---
import Layout from '@levino/shipyard-base/layouts/Page.astro'
import { type CollectionEntry, getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const news = await getCollection('news')
  return news.map((post) => ({
    params: { id: post.id },
    props: { post },
  }))
}

type Props = { post: CollectionEntry<'news'> }
const { post } = Astro.props
const { Content } = await render(post)

const dateFormatter = new Intl.DateTimeFormat('de-DE', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
})

const metadata = {
  title: post.data.title,
  description: post.data.summary,
}
---

<Layout {...metadata}>
  <article class="mx-auto max-w-3xl py-12">
    <a href="/neuigkeiten" class="btn btn-ghost btn-sm mb-8">← Alle Neuigkeiten</a>

    <header class="mb-8 border-b border-base-300 pb-8">
      <time class="text-sm font-medium text-primary">
        {dateFormatter.format(post.data.date)}
      </time>
      <h1 class="mt-2 text-4xl font-bold tracking-tight text-base-content">
        {post.data.title}
      </h1>
      <p class="mt-3 text-base-content/60">von {post.data.author}</p>
    </header>

    <div class="prose max-w-none prose-headings:scroll-mt-20">
      <Content />
    </div>
  </article>
</Layout>
