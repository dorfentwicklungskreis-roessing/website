---
interface Props {
  eyebrow?: string
  title: string
  align?: 'left' | 'center'
}
const { eyebrow, title, align = 'left' } = Astro.props
const alignClass = align === 'center' ? 'text-center mx-auto' : ''
---

<div class={`max-w-2xl ${alignClass}`}>
  {
    eyebrow && (
      <p class="text-sm font-semibold uppercase tracking-wider text-primary">
        {eyebrow}
      </p>
    )
  }
  <h2 class="mt-2 text-3xl font-bold tracking-tight text-base-content sm:text-4xl">
    {title}
  </h2>
  <div class="mt-4 text-base-content/70">
    <slot />
  </div>
</div>
